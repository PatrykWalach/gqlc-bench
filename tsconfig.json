{
	"compilerOptions": {
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"importHelpers": true,
		"target": "ES2022",
		"lib": [
			"es2016",
			"es2017.intl",
			"es2017.object",
			"es2017.string",
			"es2017.typedarrays",
			"dom",
			"esnext.asynciterable"
		],
		"skipLibCheck": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",
		"erasableSyntaxOnly": true
	}
}
